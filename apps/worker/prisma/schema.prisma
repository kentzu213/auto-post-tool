datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  owner
  editor
  approver
  viewer
}

enum Platform {
  facebook
  youtube
  tiktok
}

enum PostStatus {
  draft
  scheduled
  publishing
  published
  failed
}

enum AccountStatus {
  active
  expired
  disconnected
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workspaces   Workspace[]   @relation("WorkspaceOwner")
  teamMembers  TeamMember[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Workspace {
  id             String          @id @default(uuid())
  name           String
  ownerId        String
  owner          User            @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  teamMembers    TeamMember[]
  socialAccounts SocialAccount[]
  posts          Post[]
  campaigns      Campaign[]

  @@map("workspaces")
}

model TeamMember {
  id          String    @id @default(uuid())
  workspaceId String
  userId      String
  role        Role      @default(editor)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("team_members")
}

model SocialAccount {
  id                 String        @id @default(uuid())
  workspaceId        String
  workspace          Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platform           Platform
  platformAccountId  String        // ID của Account trên FB/YT/TikTok
  displayName        String
  username           String
  avatarUrl          String?
  accessToken        String        // AES-256-GCM encrypted
  refreshToken       String?       // AES-256-GCM encrypted
  tokenExpiresAt     DateTime?
  status             AccountStatus @default(active)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  inboxMessages      InboxMessage[]
  schedules          Schedule[]

  @@unique([platform, platformAccountId])
  @@map("social_accounts")
}

model Campaign {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  kpiTarget   String?   // KPI đích (ví dụ JSON hoặc Text)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  posts       Post[]

  @@map("campaigns")
}

model Post {
  id          String       @id @default(uuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaignId  String?
  campaign    Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  title       String?
  content     String       @db.Text
  status      PostStatus   @default(draft)
  scheduledAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  mediaAssets MediaAsset[]
  schedules   Schedule[]

  @@index([workspaceId, status])
  @@map("posts")
}

model MediaAsset {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  type      String   // 'image' | 'video'
  key       String   // S3 key để xóa file khi cần
  createdAt DateTime @default(now())

  @@map("media_assets")
}

model Schedule {
  id              String         @id @default(uuid())
  postId          String
  post            Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccountId String
  socialAccount   SocialAccount  @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  platform        Platform
  scheduledAt     DateTime
  status          PostStatus     @default(scheduled)
  errorLog        String?        @db.Text
  publishedPostId String?        // ID bài đăng sau khi thành công trên FB/YT/TikTok
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  analytics       Analytics?

  @@index([platform, status, scheduledAt])
  @@map("schedules")
}

model Analytics {
  id           String    @id @default(uuid())
  scheduleId   String    @unique
  schedule     Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  reach        Int       @default(0)
  impressions  Int       @default(0)
  engagement   Int       @default(0)
  views        Int       @default(0)
  watchTime    Float     @default(0) // Số giờ xem
  clicks       Int       @default(0)
  updatedAt    DateTime  @updatedAt

  @@map("analytics")
}

model InboxMessage {
  id              String        @id @default(uuid())
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  platform        Platform
  conversationId  String        // ID cuộc hội thoại từ API mxh
  senderId        String
  senderName      String
  senderAvatar    String?
  messageText     String        @db.Text
  isRead          Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([socialAccountId, conversationId])
  @@map("inbox_messages")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // Ví dụ: 'login', 'create_post', 'delete_account'
  details   String   @db.Text
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
