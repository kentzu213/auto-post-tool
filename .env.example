# System
PORT=3001
NODE_ENV=development

# Database (PostgreSQL 16)
# URL dùng trong prisma. Prisma kết nối trực tiếp đến PostgreSQL container chạy ở localhost:5432
DATABASE_URL="postgresql://postgres:supersecretpassword123@localhost:5432/autopost?schema=public"

# Redis Cache & Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO / AWS S3 Storage
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadminpassword123"
S3_BUCKET_NAME="autopost-media"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE=true

# Security (JWT & AES Encryption)
JWT_SECRET="yoursuperjwtsecretkeyforproductiondevelopmentchangeit"
JWT_REFRESH_SECRET="yourrefreshsecretkeyforproductiondevelopmentchangeit"
# AES-256 key phải là 32 bytes dưới dạng chuỗi hex (64 ký tự hex)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# AI Integration APIs
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# Social OAuth App Credentials
# Facebook Graph API (Meta Developers)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
FACEBOOK_REDIRECT_URI="http://localhost:3005/auth/callback/facebook"

# YouTube Data API v3 (Google Cloud Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/callback/youtube"

# TikTok Posting API (TikTok Developers)
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="http://localhost:3005/auth/callback/tiktok"

# Anthropic Claude API (Phase 5)
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-sonnet-4-20250514"

# AI Model Selection (override defaults)
GEMINI_MODEL="gemini-2.0-flash"
OPENAI_MODEL="gpt-4o"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
CORS_ORIGIN="http://localhost:3005"

