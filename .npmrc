# Flat, npm-style node_modules (no symlinks) so the production Docker images —
# which copy only the repo-root /app/node_modules — resolve every dependency at
# runtime. The default pnpm layout keeps each app's deps under
# apps/<app>/node_modules (symlinked into node_modules/.pnpm), which never made
# it into the runner image: `prisma` (migrate) and `@nestjs/*` (api) were not
# found. `hoisted` puts all packages physically in the root node_modules.
node-linker=hoisted
